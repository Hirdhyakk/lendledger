# Copy values into Render / Vercel dashboards. Do not commit real secrets.

# --- Neon PostgreSQL (all 5 backend services) ---
DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=

# --- Upstash Redis (gateway, loan, payment, notification) ---
# Use the TLS URL from Upstash console (starts with rediss://)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# --- Shared secrets (same value on ALL backend services) ---
JWT_SECRET=replace-with-64-char-random-string
INTERNAL_API_KEY=replace-with-random-internal-key

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
JAVA_OPTS=-Xmx384m -XX:+UseContainerSupport

# --- Render service URLs (after each service is live; gateway + loan + payment) ---
AUTH_SERVICE_URL=https://lendledger-auth.onrender.com
LOAN_SERVICE_URL=https://lendledger-loan.onrender.com
PAYMENT_SERVICE_URL=https://lendledger-payment.onrender.com
NOTIFICATION_SERVICE_URL=https://lendledger-notification.onrender.com

# Gateway only (exact Vercel URL, no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app

# Vercel frontend
# VITE_API_URL must end with /api

# --- Vercel (frontend) ---
VITE_API_URL=https://lendledger-gateway.onrender.com/api
